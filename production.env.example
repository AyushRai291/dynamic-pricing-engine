# Copy to an untracked .env.production and replace every CHANGE_ME value.
POSTGRES_USER=dpe_app
POSTGRES_PASSWORD=CHANGE_ME_URL_SAFE_DATABASE_PASSWORD
POSTGRES_DB=dynamic_pricing
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_REFRESH_SECRET
CORS_ALLOWED_ORIGINS=https://pricing.example.com
WEB_PORT=8080

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=120
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_EXPENSIVE_MAX=10
PRICE_SUGGESTION_TTL_HOURS=24
QUEUE_REDIS_CONNECT_TIMEOUT_MS=5000
QUEUE_REDIS_COMMAND_TIMEOUT_MS=5000
SCRAPER_CRON_ENABLED=true
SCRAPER_CRON_EXPRESSION=0 */4 * * *
# Production Compose disables Chromium's inner sandbox because Docker blocks its namespaces.
# The API still runs non-root with a read-only filesystem and no-new-privileges.
SCRAPER_MAX_HTML_BYTES=2000000
SCRAPER_MAX_REDIRECTS=5
ML_REQUEST_TIMEOUT_MS=5000

# Optional. Leave empty when Gemini rationale generation is not configured.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_REQUEST_TIMEOUT_MS=10000
GEMINI_MAX_OUTPUT_TOKENS=600
