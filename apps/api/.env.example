PORT=5000
DATABASE_URL=postgresql://dpe_user:dpe_password@localhost:5432/dynamic_pricing
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
TRUST_PROXY=0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=120
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_EXPENSIVE_MAX=10
REDIS_URL=redis://127.0.0.1:6379
QUEUE_REDIS_CONNECT_TIMEOUT_MS=5000
QUEUE_REDIS_COMMAND_TIMEOUT_MS=5000
SCRAPER_CRON_ENABLED=false
SCRAPER_CRON_EXPRESSION=0 */4 * * *
# Private URLs are blocked in production even if this test/development override is set.
SCRAPER_ALLOW_PRIVATE_URLS=false
SCRAPER_DISABLE_CHROMIUM_SANDBOX=false
SCRAPER_MAX_HTML_BYTES=2000000
SCRAPER_MAX_REDIRECTS=5
ML_SERVICE_URL=http://127.0.0.1:8000
ML_REQUEST_TIMEOUT_MS=5000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_REQUEST_TIMEOUT_MS=10000
GEMINI_MAX_OUTPUT_TOKENS=600
